{
  "rewrites": [
    { "source": "/", "destination": "/brand-os/index.html" },
    { "source": "/brand-os", "destination": "/brand-os/index.html" },
    { "source": "/brand-os/login", "destination": "/brand-os/login.html" },
    { "source": "/brand-os/hub", "destination": "/brand-os/hub.html" },
    { "source": "/brand-os/copywriter", "destination": "/brand-os/copywriter.html" },
    { "source": "/brand-os/art-director", "destination": "/brand-os/art-director.html" },
    { "source": "/brand-os/admin", "destination": "/brand-os/admin.html" },
    { "source": "/:slug([a-z][a-z0-9-]{1,40})", "destination": "/brand-os/login.html?slug=:slug" }
  ],
  "functions": {
    "api/brand-os/art-director.js": { "maxDuration": 60 }
  }
}
